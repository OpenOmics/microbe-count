# Python standard library
from os.path import join
import os, json
# 3rd party imports from pypi
from snakemake.io import expand
# Local imports
from scripts.common import (
    allocated,
    provided,
    str_bool
)


# Converts taxonomic level abbreviations
# to their full names for output filenames
TAXONOMY_MAP = {
    'D': 'domain', 'K': 'kingdom',
    'P': 'phylum', 'C': 'class',
    'O': 'order',  'F': 'family',
    'G': 'genus',  'S': 'species'
}
# Maps full name of taxonomic level to
# its corresponding abbreviated level
# for bracken to re-estimate abundances
# at the specified taxonomic level
BRACKEN_MAP = {
    'domain': 'D', 'kingdom': 'K',
    'phylum': 'P', 'class':   'C',
    'order':  'O', 'family':  'F',
    'genus':  'G', 'species': 'S'
}

# Global workflow variables
configfile: 'config.json'                       # Generated from user input and config/*.json
bindpath = config['bindpaths']                  # Singularity paths to bind to the container
samples  = sorted(config['samples'])            # Base name of input samples
workpath = config['project']['workpath']        # Pipeline's output directory
kdb_path = config['options']['kraken2_db_path'] # Kraken2 db for estimating contamination
batch_id = config['options']['batch_id']        # Batch Identifer, default: ''.
taxa_abr = config['options']['taxonomic_level'] # Taxonomic level(s) abbreviation for bracken
taxa_lvl = [TAXONOMY_MAP[t] for t in taxa_abr]  # Taxonomic level(s) full name for output filenames

# Read in resource information,
# containing information about
# threads, mem, walltimes, etc.
# TODO: Add handler for when the
# mode is set to local.
with open(join(workpath, 'config', 'cluster.json')) as fh:
    cluster = json.load(fh)


# Final output files of the pipeline
rule all:
    input:
        # Create host removed FastQ files,
        # extracts unmapped reads from the
        # input host-aligned BAM files and
        # trim them with fastp, untrimmed
        # fastq files are temp files
        # @imported from rules/host_removal.smk
        # @output of rule fastp
        expand(join(workpath, "{name}", "fastqs", "{name}.R1.trimmed.fastq.gz"), name=samples),
        expand(join(workpath, "{name}", "fastqs", "{name}.R2.trimmed.fastq.gz"), name=samples),
        # Alignment statistics on input BAM files,
        # including flagstat, stats, and idxstats
        # @imported from rules/qc.smk
        # @output of rule alignment_stats
        expand(join(workpath, "{name}", "qc", "{name}.flagstats"), name=samples),
        expand(join(workpath, "{name}", "qc", "{name}.stats"), name=samples),
        expand(join(workpath, "{name}", "qc", "{name}.idxstats"), name=samples),
        # FastQC reports on host removed FastQ files
        # @imported from rules/qc.smk
        # @output of rule fastqc_extracted_reads
        expand(join(workpath, "{name}", "qc", "{name}.R1_fastqc.zip"), name=samples),
        expand(join(workpath, "{name}", "qc", "{name}.R2_fastqc.zip"), name=samples),
        # Run kraken2 on host removed FastQ files
        # @imported from rules/classification.smk
        # @output of rule kraken2_classification
        expand(join(workpath, "{name}", "kraken2", "{name}_kraken2.report"), name=samples),
        # Run bracken to re-estimate microbial abundances
        # at user defined taxonomic level(s)
        # @imported from rules/classification.smk
        # @output of rule bracken_abundance_estimation
        expand(
            join(workpath, "{name}", "bracken", "{name}_bracken_{level}-level.tsv"),
            name=samples,
            level=taxa_lvl
        ),
        # Create counts matrix of bracken re-estimated
        # abundances at user defined taxonomic level(s)
        # @imported from rules/classification.smk
        # @output of rule taxpasta_counts_matrix
        expand(
            join(workpath, "counts", "bracken_{level}-level_estimated-counts.tsv"),
            level=taxa_lvl
        ),
        # Run multiqc to aggregate and summarize QC
        # metrics across samples
        # @imported from rules/qc.smk
        # @output of rule multiqc
        join(workpath, "report", batch_id, "multiqc_report.html"),


# Import rules
include: join("rules", "host_removal.smk")
include: join("rules", "qc.smk")
include: join("rules", "classification.smk")
include: join("rules", "common.smk")
include: join("rules", "hooks.smk")